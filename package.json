{
  "name": "open-in-new-window",
  "displayName": "Open In New Window",
  "description": "Adds explorer context menu commands to open a folder in a new VS Code window and open git repositories from folders that contain .git.",
  "version": "0.0.1",
  "publisher": "xhd2015",
  "repository": {
    "type": "git",
    "url": "https://github.com/xhd2015/Vscode-Ext-Open-In-New-Window"
  },
  "engines": {
    "vscode": "^1.119.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onUri"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "open-in-new-window.open",
        "title": "Open in New Window"
      },
      {
        "command": "open-in-new-window.gitOpenRepository",
        "title": "Git: Open Repository",
        "category": "Git"
      },
      {
        "command": "open-in-new-window.debugGitPaths",
        "title": "Open In New Window: Debug Git Paths"
      },
      {
        "command": "open-in-new-window.openITerm2",
        "title": "Open iTerm2",
        "category": "Open In New Window"
      },
      {
        "command": "open-in-new-window.openITerm2Grok",
        "title": "Open iTerm2: Grok",
        "category": "Open In New Window"
      },
      {
        "command": "open-in-new-window.openITerm2Codex",
        "title": "Open iTerm2: Codex",
        "category": "Open In New Window"
      },
      {
        "command": "open-in-new-window.openITerm2Claude",
        "title": "Open iTerm2: Claude Code",
        "category": "Open In New Window"
      },
      {
        "command": "open-in-new-window.openITerm2OpenCode",
        "title": "Open iTerm2: OpenCode",
        "category": "Open In New Window"
      },
      {
        "command": "open-in-new-window.openITerm2Pi",
        "title": "Open iTerm2: Pi",
        "category": "Open In New Window"
      },
      {
        "command": "open-in-new-window.switchITerm2Shortcut",
        "title": "Switch Shortcut",
        "category": "Open In New Window"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "open-in-new-window.open",
          "when": "resourceScheme == file",
          "group": "navigation@10"
        },
        {
          "command": "open-in-new-window.gitOpenRepository",
          "when": "explorerResourceIsFolder && resourceScheme == file && (resourcePath in openInNewWindow.gitRepositoryPathKeys || resourceFilename in openInNewWindow.gitRepositoryPathKeys)",
          "group": "navigation@11"
        },
        {
          "command": "open-in-new-window.debugGitPaths",
          "when": "explorerResourceIsFolder && resourceScheme == file && openInNewWindow.isDevelopment",
          "group": "navigation@12"
        }
      ],
      "commandPalette": [
        {
          "command": "open-in-new-window.open",
          "when": "false"
        },
        {
          "command": "open-in-new-window.gitOpenRepository",
          "when": "false"
        },
        {
          "command": "open-in-new-window.debugGitPaths",
          "when": "false"
        },
        {
          "command": "open-in-new-window.openITerm2"
        },
        {
          "command": "open-in-new-window.openITerm2Grok"
        },
        {
          "command": "open-in-new-window.openITerm2Codex"
        },
        {
          "command": "open-in-new-window.openITerm2Claude"
        },
        {
          "command": "open-in-new-window.openITerm2OpenCode"
        },
        {
          "command": "open-in-new-window.openITerm2Pi"
        },
        {
          "command": "open-in-new-window.switchITerm2Shortcut"
        }
      ]
    },
    "keybindings": [
      {
        "command": "open-in-new-window.openITerm2Shortcut",
        "key": "cmd+;",
        "mac": "cmd+;",
        "when": "isMac"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test",
    "ui-test:setup": "extest setup-tests --code_version 1.124.2 --extensions_dir .test-extensions",
    "ui-test": "npm run compile && extest setup-and-run 'out/ui-test/**/*.test.js' --code_version 1.124.2 --extensions_dir .test-extensions --code_settings ui-test/settings.json --mocha_config .mocharc.ui-test.js",
    "ui-test:run": "extest run-tests 'out/ui-test/**/*.test.js' --extensions_dir .test-extensions --code_settings ui-test/settings.json --mocha_config .mocharc.ui-test.js",
    "ui-test:open-iterm2": "npm run compile && extest setup-and-run 'out/ui-test/open-iterm2.test.js' --code_version 1.124.2 --extensions_dir .test-extensions --code_settings ui-test/settings.json --mocha_config .mocharc.ui-test.js",
    "ui-test:switch-iterm2-shortcut": "npm run compile && extest setup-and-run 'out/ui-test/switch-iterm2-shortcut.test.js' --code_version 1.124.2 --extensions_dir .test-extensions --code_settings ui-test/settings.json --mocha_config .mocharc.ui-test.js",
    "package": "npx @vscode/vsce package"
  },
  "devDependencies": {
    "@types/chai": "^4.3.16",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.119.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "chai": "^4.5.0",
    "eslint": "^9.39.3",
    "mocha": "^11.7.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vscode-extension-tester": "^8.23.0"
  }
}
