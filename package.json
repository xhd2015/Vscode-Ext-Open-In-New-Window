{
  "name": "open-in-new-window",
  "displayName": "Open In New Window",
  "description": "Adds explorer context menu commands to open a folder in a new VS Code window and open git repositories from folders that contain .git.",
  "version": "0.0.1",
  "publisher": "xhd2015",
  "repository": {
    "type": "git",
    "url": "https://github.com/xhd2015/Vscode-Ext-Open-In-New-Window"
  },
  "engines": {
    "vscode": "^1.119.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "open-in-new-window.open",
        "title": "Open in New Window"
      },
      {
        "command": "open-in-new-window.gitOpenRepository",
        "title": "Git: Open Repository",
        "category": "Git"
      },
      {
        "command": "open-in-new-window.debugGitPaths",
        "title": "Open In New Window: Debug Git Paths"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "open-in-new-window.open",
          "when": "resourceScheme == file",
          "group": "navigation@10"
        },
        {
          "command": "open-in-new-window.gitOpenRepository",
          "when": "explorerResourceIsFolder && resourceScheme == file && resourcePath in openInNewWindow.gitRepositoryPaths",
          "group": "navigation@11"
        },
        {
          "command": "open-in-new-window.debugGitPaths",
          "when": "explorerResourceIsFolder && resourceScheme == file && openInNewWindow.isDevelopment",
          "group": "navigation@12"
        }
      ],
      "commandPalette": [
        {
          "command": "open-in-new-window.open",
          "when": "false"
        },
        {
          "command": "open-in-new-window.gitOpenRepository",
          "when": "false"
        },
        {
          "command": "open-in-new-window.debugGitPaths",
          "when": "false"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test",
    "package": "npx @vscode/vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.119.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}